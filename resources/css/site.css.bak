html,
body {
    overflow-x: hidden;
}

body.compro-shell {
    background-color: #050505;
}

.compro-shell::-webkit-scrollbar {
    width: 8px;
}

.compro-shell::-webkit-scrollbar-track {
    background: #050505;
}

.compro-shell::-webkit-scrollbar-thumb {
    background: #333333;
    border-radius: 4px;
}

.compro-shell::-webkit-scrollbar-thumb:hover {
    background: #555555;
}

.hero-glow {
    position: absolute;
    width: 80vw;
    max-width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.04) 0%, rgba(5, 5, 5, 0) 70%);
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    z-index: -1;
    pointer-events: none;
}

.global-nav {
    position: sticky;
    top: 0;
    z-index: 9999;
}

.global-nav .nav-wrap {
    background: linear-gradient(90deg, rgba(6, 6, 6, 0.92), rgba(14, 14, 14, 0.86));
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    box-shadow: 0 8px 32px rgba(2, 6, 23, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
}

.global-nav .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 22px;
    gap: 18px;
}

.nav-brand-group {
    display: flex;
    align-items: center;
    gap: 16px;
}

.nav-logo-link {
    display: inline-flex;
    align-items: center;
}

.nav-logo {
    height: 64px;
    transition: transform 0.18s ease, filter 0.18s ease;
    display: block;
}

.nav-logo:hover {
    transform: translateY(-4px) scale(1.02);
    filter: drop-shadow(0 12px 30px rgba(0, 0, 0, 0.6));
}

.nav-links {
    display: flex;
    align-items: center;
    gap: 18px;
}

.nav-links a {
    color: #ffffff;
    text-decoration: none;
    font-weight: 600;
    padding: 6px 4px;
    position: relative;
    opacity: 0.95;
    transition: color 0.14s ease, transform 0.14s ease;
}

.nav-links a:before {
    content: '';
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 0;
    height: 3px;
    border-radius: 3px;
    background: linear-gradient(90deg, #ffd166, #ff6b6b);
    transition: width 0.22s cubic-bezier(.2, .9, .2, 1);
}

.nav-links a:hover {
    transform: translateY(-4px);
    color: #ffffff;
}

.nav-links a:hover:before,
.nav-links a.active:before {
    width: 100%;
}

.nav-actions {
    display: flex;
    align-items: center;
    gap: 10px;
}

.nav-profile-wrap {
    position: relative;
}

.nav-profile-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: none;
    padding: 6px;
    border-radius: 10px;
    cursor: pointer;
}

.nav-avatar {
    width: 36px;
    height: 36px;
    border-radius: 999px;
    border: 2px solid rgba(255, 255, 255, 0.04);
    object-fit: cover;
}

.nav-avatar-fallback {
    border-radius: 999px;
    border: 2px solid rgba(255, 255, 255, 0.04);
    background: transparent;
}

.nav-profile-menu {
    display: none;
    position: absolute;
    right: 0;
    margin-top: 8px;
    background: linear-gradient(180deg, #0b0b0b, #0e0e0e);
    border-radius: 10px;
    padding: 8px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.6);
    min-width: 180px;
    z-index: 999;
}

.nav-profile-menu.show {
    display: block;
}

.nav-profile-menu__header {
    padding: 8px 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.02);
}

.nav-profile-menu__name {
    font-weight: 700;
}

.nav-profile-menu__email {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.65);
}

.nav-profile-menu__link {
    display: block;
    padding: 8px 10px;
    color: #ffffff;
    text-decoration: none;
}

.nav-profile-menu__button {
    width: 100%;
    text-align: left;
    padding: 8px 10px;
    border: none;
    background: transparent;
    color: #ffffff;
    cursor: pointer;
}

.nav-username {
    color: rgba(255, 255, 255, 0.92);
    font-weight: 600;
    opacity: 0.95;
}

.btn-ghost {
    background: transparent;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 8px 12px;
    border-radius: 10px;
    font-weight: 700;
    transition: transform 0.12s ease, box-shadow 0.12s ease, background 0.12s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.btn-ghost:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.5);
    background: rgba(255, 255, 255, 0.03);
}

.btn-ghost--block {
    width: 100%;
}

.nav-login-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    color: #ffffff;
    padding: 10px 14px;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 700;
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: transform 0.14s ease, box-shadow 0.14s ease, opacity 0.14s ease;
}

.nav-login-button svg {
    width: 18px;
    height: 18px;
}

.nav-toggle {
    display: none;
    background: transparent;
    border: none;
    color: #ffffff;
    padding: 8px;
    border-radius: 8px;
}

@media (max-width: 900px) {
    .nav-links {
        display: none;
        position: absolute;
        left: 16px;
        right: 16px;
        top: 84px;
        flex-direction: column;
        gap: 10px;
        background: linear-gradient(180deg, rgba(10, 10, 10, 0.96), rgba(8, 8, 8, 0.98));
        border-radius: 12px;
        padding: 14px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
    }

    .nav-links.show {
        display: flex;
    }

    .nav-logo {
        height: 52px;
    }

    .global-nav .nav-inner {
        padding: 10px 16px;
    }

    .nav-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
}

.app-admin-subnav {
    background: #0b1220;
    color: #ffffff;
    padding: 8px 20px;
    border-bottom: 1px solid #0f1724;
}

.app-admin-subnav__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 18px;
}

.app-admin-subnav a,
.app-admin-subnav a:visited {
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
}

.profile-view-container {
    max-width: 1000px;
    margin: 40px auto;
    padding: 20px;
    color: #ffffff;
}

@media (max-width: 640px) {
    .profile-view-container {
        margin: 18px auto;
        padding: 12px;
    }
}

.profile-grid {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 24px;
    align-items: start;
}

@media (max-width: 900px) {
    .profile-grid {
        grid-template-columns: 1fr;
        gap: 16px;
    }
}

.profile-sidebar {
    flex: 0 0 260px;
    background: linear-gradient(180deg, #0b0b0b, #0f0f0f);
    padding: 20px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.6);
}

@media (max-width: 640px) {
    .profile-sidebar {
        padding: 14px;
    }
}

.profile-main {
    background: linear-gradient(180deg, #070707, #0c0c0c);
    padding: 22px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.03);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
}

@media (max-width: 640px) {
    .profile-main {
        padding: 14px;
    }
}

.profile-sidebar__stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
}

.avatar-wrap {
    width: 120px;
    height: 120px;
    border-radius: 999px;
    overflow: hidden;
    border: 4px solid rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    background: #111111;
}

.avatar-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.03);
    opacity: 0.98;
    display: block;
}

@media (max-width: 900px) {
    .avatar-wrap {
        width: 110px;
        height: 110px;
    }
}

@media (max-width: 420px) {
    .avatar-wrap {
        width: 92px;
        height: 92px;
    }
}

.avatar-fallback {
    display: block;
    fill: #ffffff;
}

.profile-name {
    font-weight: 800;
    font-size: 18px;
}

.profile-email {
    color: rgba(255, 255, 255, 0.65);
    font-size: 13px;
}

.profile-stack-block {
    width: 100%;
    margin-top: 10px;
}

.profile-section-title {
    margin: 0 0 12px 0;
}

.account-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}

@media (max-width: 720px) {
    .account-grid {
        grid-template-columns: 1fr;
    }
}

.info-card {
    background: rgba(255, 255, 255, 0.02);
    padding: 12px;
    border-radius: 10px;
}

.info-card--full {
    grid-column: 1 / -1;
}

.info-label {
    color: rgba(255, 255, 255, 0.8);
    font-weight: 700;
}

.info-value {
    color: rgba(255, 255, 255, 0.6);
}

.actions-row {
    margin-top: 18px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}

@media (max-width: 420px) {
    .actions-row .btn-ghost {
        flex: 1 1 100%;
        text-align: center;
    }
}

.profile-referral-row {
    margin-top: 18px;
    display: flex;
    gap: 10px;
    align-items: center;
}

.profile-referral-card {
    background: rgba(255, 255, 255, 0.02);
    padding: 10px;
    border-radius: 10px;
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
}

.profile-referral-label {
    font-weight: 700;
    color: rgba(255, 255, 255, 0.85);
}

.profile-referral-code {
    color: rgba(255, 255, 255, 0.6);
    font-family: monospace;
    padding: 6px 10px;
    background: rgba(0, 0, 0, 0.25);
    border-radius: 6px;
}

.profile-referral-note {
    color: rgba(255, 255, 255, 0.55);
    font-size: 12px;
}

.profile-referral-note a,
.profile-referral-note a:visited {
    color: #ffffff;
    text-decoration: underline;
}

.status-stack {
    margin-bottom: 14px;
}

.status-banner {
    padding: 12px;
    border-radius: 10px;
    color: #ffffff;
    font-weight: 600;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
}

.status-banner + .status-banner {
    margin-top: 10px;
}

.status-banner--success {
    background: linear-gradient(90deg, #0b7a44, #11998e);
    box-shadow: 0 8px 30px rgba(12, 120, 68, 0.18);
}

.status-banner--error {
    background: linear-gradient(90deg, #c0392b, #e74c3c);
    box-shadow: 0 8px 30px rgba(224, 67, 67, 0.12);
}

.status-errors {
    margin: 0;
    padding-left: 18px;
}

.referrals-page {
    max-width: 900px;
    margin: 40px auto;
    padding: 20px;
    color: #ffffff;
}

.referrals-summary,
.referrals-table-card {
    background: rgba(255, 255, 255, 0.02);
    padding: 14px;
    border-radius: 10px;
}

.referrals-count {
    margin-bottom: 12px;
    color: rgba(255, 255, 255, 0.75);
}

.referrals-summary {
    margin-bottom: 14px;
}

.referrals-summary__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    justify-content: space-between;
}

.referrals-summary__column {
    min-width: 220px;
}

.referrals-summary__title,
.referrals-link-title {
    font-weight: 800;
    margin-bottom: 8px;
    color: rgba(255, 255, 255, 0.9);
}

.referrals-summary__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    color: rgba(255, 255, 255, 0.75);
}

.referrals-summary__value {
    text-align: right;
}

.referrals-linkbox {
    flex: 1;
    min-width: 260px;
}

.referrals-link-row {
    display: flex;
    gap: 8px;
    align-items: center;
}

.referral-input {
    flex: 1;
    padding: 8px 10px;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.25);
    color: #dddddd;
    border: 1px solid rgba(255, 255, 255, 0.07);
    font-family: monospace;
}

.referrals-note,
.referrals-empty {
    margin-top: 6px;
    color: rgba(255, 255, 255, 0.55);
    font-size: 12px;
}

.referrals-empty {
    color: rgba(255, 255, 255, 0.6);
}

.referrals-table {
    width: 100%;
    border-collapse: collapse;
}

.referrals-table thead tr {
    text-align: left;
    color: rgba(255, 255, 255, 0.8);
}

.referrals-table th,
.referrals-table td {
    padding: 8px 6px;
}

.referrals-table tbody tr + tr {
    border-top: 1px solid rgba(255, 255, 255, 0.03);
}

.referrals-table tbody td {
    padding: 10px 6px;
}

.referrals-actions {
    margin-top: 12px;
}

.profile-edit-page {
    max-width: 900px;
    margin: 40px auto;
    padding: 20px 18px;
    color: #ffffff;
    width: 100%;
}

@media (max-width: 640px) {
    .profile-edit-page {
        margin: 18px auto;
        padding: 12px 12px;
    }
}

.profile-edit-header {
    margin-bottom: 32px;
}

.profile-edit-title {
    margin: 0 0 8px;
    font-size: 42px;
    line-height: 1.1;
    letter-spacing: -0.03em;
    font-weight: 900;
    background: linear-gradient(135deg, #ffffff 0%, #d0d0d0 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.profile-edit-subtitle {
    margin: 0;
    color: #888888;
    font-size: 15px;
}

.profile-edit-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
}

.profile-edit-photo-section {
    text-align: center;
    margin-bottom: 6px;
}

.profile-edit-photo-action {
    margin-top: 12px;
}

.profile-edit-photo-wrap {
    margin: 0 auto;
    border-radius: 999px;
    overflow: hidden;
    border: 3px solid rgba(255, 255, 255, 0.06);
    background: #0b0b0b;
    display: flex;
    align-items: center;
    justify-content: center;
}

#photo-wrap {
    width: 140px;
    height: 140px;
}

@media (max-width: 900px) {
    #photo-wrap {
        width: 120px;
        height: 120px;
    }
}

@media (max-width: 600px) {
    #photo-wrap {
        width: 96px;
        height: 96px;
    }
}

.profile-edit-photo-preview {
    transition: opacity 0.18s ease, transform 0.18s ease;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
}

#photo-preview {
    transition: opacity 0.18s ease, transform 0.18s ease;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.profile-edit-change-photo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(180deg, #111111, #0f0f0f);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 10px 14px;
    border-radius: 10px;
    color: #ffffff;
    font-weight: 700;
    cursor: pointer;
}

.profile-section {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    background: linear-gradient(180deg, rgba(30, 30, 30, 0.6) 0%, rgba(20, 20, 20, 0.4) 100%);
    backdrop-filter: blur(10px);
    padding: 28px;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-sizing: border-box;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

.profile-section h3 {
    color: #ffffff;
    font-weight: 800;
    letter-spacing: -0.02em;
}

.profile-section p {
    color: #a3a3a3;
    font-size: 14px;
}

.profile-edit-section-title {
    margin: 0 0 12px 0;
}

.profile-edit-section-copy {
    margin: 0 0 16px;
    color: rgba(255, 255, 255, 0.65);
}

@media (max-width: 640px) {
    .profile-section {
        padding: 20px;
        margin: 0 6px;
        border-radius: 14px;
    }
}

.profile-form {
    max-width: 520px;
    margin: 0 auto;
    width: 100%;
}

@media (max-width: 520px) {
    .profile-form {
        padding: 0 6px;
        width: 100%;
    }
}

.profile-edit-field {
    margin-bottom: 16px;
}

.profile-edit-label {
    display: block;
    font-weight: 700;
    margin-bottom: 8px;
    font-size: 14px;
}

.profile-edit-input {
    width: 100%;
    padding: 12px 14px;
    border-radius: 10px;
    background: rgba(10, 10, 10, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: #ffffff;
    font-size: 14px;
    transition: all 0.2s ease;
}

.profile-edit-error {
    color: #ff9999;
    margin-top: 6px;
    font-size: 13px;
}

.profile-edit-error--center {
    color: #ffb4b4;
    margin-top: 6px;
    text-align: center;
}

.profile-edit-file-input {
    display: none;
}

.profile-edit-cropper-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    z-index: 2000;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
}

.profile-edit-cropper-modal.open {
    opacity: 1;
    pointer-events: auto;
}

.profile-edit-cropper-dialog {
    transform: translateY(6px) scale(0.98);
    transition: transform 0.22s cubic-bezier(.2, .9, .2, 1), opacity 0.18s ease;
    opacity: 0.98;
    max-height: calc(100vh - 80px);
    overflow: auto;
    box-sizing: border-box;
    width: 100%;
    max-width: 760px;
    background: linear-gradient(180deg, #0b0b0b, #0f0f0f);
    border-radius: 12px;
    padding: 16px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6);
}

.profile-edit-cropper-modal.open .profile-edit-cropper-dialog {
    transform: translateY(0) scale(1);
    opacity: 1;
}

.blur-backdrop {
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
}

.profile-edit-cropper-inner {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    flex-direction: column;
}

.profile-edit-cropper-top {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.profile-edit-cropper-title {
    font-weight: 700;
    color: #ffffff;
}

.profile-edit-cropper-actions {
    display: flex;
    gap: 8px;
    align-items: center;
}

.profile-edit-cropper-button {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 8px 10px;
    border-radius: 8px;
    color: #ffffff;
    cursor: pointer;
}

.profile-edit-cropper-button--primary {
    background: linear-gradient(90deg, #ffd166, #ff6b6b);
    border: none;
    color: #111111;
    font-weight: 800;
}

.profile-edit-cropper-stage {
    display: flex;
    gap: 12px;
    flex-direction: column;
    align-items: center;
}

.profile-edit-crop-area {
    width: min(420px, 86vw);
    aspect-ratio: 1 / 1;
    height: auto;
    background: #111111;
    overflow: hidden;
    position: relative;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    touch-action: none;
}

.profile-edit-crop-area img {
    position: absolute;
    left: 0;
    top: 0;
    will-change: transform;
    user-select: none;
    -webkit-user-drag: none;
}

.profile-edit-crop-overlay {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 80%;
    height: 80%;
    border: 2px dashed rgba(255, 255, 255, 0.18);
    box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.35) inset;
    pointer-events: none;
    border-radius: 6px;
}

.profile-edit-zoom-row {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
}

.profile-edit-zoom-label {
    color: rgba(255, 255, 255, 0.8);
    font-weight: 700;
}

.profile-edit-zoom-input {
    width: 220px;
}

.profile-edit-password-section {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    background: linear-gradient(180deg, rgba(30, 30, 30, 0.6) 0%, rgba(20, 20, 20, 0.4) 100%);
    backdrop-filter: blur(10px);
    padding: 28px;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

.profile-edit-password-form {
    max-width: 520px;
    margin: 0 auto;
}

.profile-edit-password-group {
    margin-bottom: 12px;
}

.profile-edit-password-label {
    display: block;
    font-weight: 700;
    margin-bottom: 6px;
}

.profile-edit-password-wrap {
    position: relative;
}

.profile-edit-password-input {
    width: 100%;
    padding: 10px 40px 10px 10px;
    border-radius: 6px;
    background: #0b0b0b;
    border: 1px solid rgba(255, 255, 255, 0.04);
    color: #ffffff;
}

.profile-edit-password-toggle {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    padding: 6px 8px;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
}

.profile-edit-password-error {
    color: #ffb4b4;
    margin-top: 6px;
}

.profile-edit-actions {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-top: 6px;
}

.profile-edit-submit {
    background: linear-gradient(90deg, #00d4ff 0%, #0099ff 100%);
    border: none;
    padding: 12px 20px;
    border-radius: 10px;
    color: #000000;
    font-weight: 700;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.2s ease;
}

.profile-edit-cancel {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    padding: 12px 16px;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: all 0.2s ease;
    font-weight: 600;
}

.lms-dashboard {
    min-height: calc(100vh - 120px);
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
    padding: 40px 16px 54px;
    color: #f5f5f5;
}

.lms-dashboard__inner {
    max-width: 1200px;
    margin: 0 auto;
}

.lms-dashboard__header {
    margin-bottom: 32px;
}

.lms-dashboard__title {
    margin: 0 0 8px;
    font-size: 42px;
    line-height: 1.1;
    letter-spacing: -0.03em;
    font-weight: 900;
    background: linear-gradient(135deg, #ffffff 0%, #d0d0d0 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.lms-dashboard__subtitle {
    margin: 0;
    color: #888888;
    font-size: 15px;
}

.lms-progress-card,
.lms-stat-card,
.lms-action-card {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    background: linear-gradient(180deg, rgba(30, 30, 30, 0.6) 0%, rgba(20, 20, 20, 0.4) 100%);
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

.lms-progress-card {
    padding: 28px;
    margin-bottom: 28px;
}

.lms-progress-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
}

.lms-progress-card__label {
    margin: 0 0 6px;
    font-size: 16px;
    font-weight: 700;
    color: #a3a3a3;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.lms-progress-card__label svg,
.lms-stat-icon svg,
.lms-action-card__icon svg {
    display: inline;
    vertical-align: text-bottom;
}

.lms-progress-card__desc {
    margin: 0;
    color: #666666;
    font-size: 13px;
}

.lms-progress-card__summary {
    text-align: right;
}

.lms-progress-card__percent {
    font-size: 44px;
    font-weight: 900;
    background: linear-gradient(135deg, #00d4ff 0%, #0099ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
}

.lms-progress-card__count {
    margin: 6px 0 0;
    color: #666666;
    font-size: 12px;
}

.lms-progress-bar {
    height: 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    overflow: hidden;
    margin-bottom: 12px;
}

.lms-progress-bar__fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, #00d4ff 0%, #0099ff 100%);
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.lms-progress-card__note {
    display: flex;
    gap: 12px;
    font-size: 12px;
    color: #666666;
}

.lms-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 28px;
}

.lms-stat-card {
    padding: 20px;
    border-radius: 16px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
}

.lms-stat-icon {
    font-size: 24px;
    margin-bottom: 8px;
}

.lms-stat-label {
    font-size: 13px;
    color: #888888;
    margin-bottom: 6px;
}

.lms-stat-value {
    font-size: 32px;
    font-weight: 900;
    margin-bottom: 4px;
}

.lms-stat-caption {
    margin: 0;
    font-size: 12px;
    color: #666666;
}

.lms-stat-card--coaching .lms-stat-value,
.lms-stat-card--coaching .lms-stat-icon {
    color: #ff6b6b;
}

.lms-stat-card--tickets .lms-stat-value,
.lms-stat-card--tickets .lms-stat-icon {
    color: #ffd700;
}

.lms-stat-card--topics .lms-stat-value,
.lms-stat-card--topics .lms-stat-icon {
    color: #00d4ff;
}

.lms-actions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
}

.lms-action-card {
    text-decoration: none;
    color: #f5f5f5;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 200px;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    position: relative;
    overflow: hidden;
    border-radius: 18px;
}

.lms-action-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.2);
}

.lms-action-card__glow {
    position: absolute;
    right: -30px;
    top: -30px;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    pointer-events: none;
}

.lms-action-card__glow--courses {
    background: rgba(0, 212, 255, 0.05);
}

.lms-action-card__glow--coaching {
    background: rgba(255, 107, 107, 0.05);
}

.lms-action-card__glow--song {
    background: rgba(255, 215, 0, 0.05);
}

.lms-action-card__icon {
    font-size: 28px;
    margin-bottom: 12px;
}

.lms-action-card__title {
    font-size: 20px;
    font-weight: 800;
    margin-bottom: 8px;
}

.lms-action-card__body {
    font-size: 13px;
    color: #a3a3a3;
    line-height: 1.5;
}

.lms-action-card__footer {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
}

.lms-action-card__arrow {
    font-size: 16px;
}

.lms-action-card--courses {
    background: linear-gradient(180deg, rgba(0, 212, 255, 0.08) 0%, rgba(0, 153, 255, 0.04) 100%);
    box-shadow: 0 4px 20px rgba(0, 212, 255, 0.1);
}

.lms-action-card--coaching {
    background: linear-gradient(180deg, rgba(255, 107, 107, 0.08) 0%, rgba(255, 153, 0, 0.04) 100%);
    box-shadow: 0 4px 20px rgba(255, 107, 107, 0.1);
}

.lms-action-card--song {
    background: linear-gradient(180deg, rgba(255, 215, 0, 0.08) 0%, rgba(255, 165, 0, 0.04) 100%);
    box-shadow: 0 4px 20px rgba(255, 215, 0, 0.1);
}

.lms-action-card--courses .lms-action-card__footer,
.lms-action-card--courses .lms-action-card__icon {
    color: #00d4ff;
}

.lms-action-card--coaching .lms-action-card__footer,
.lms-action-card--coaching .lms-action-card__icon {
    color: #ff6b6b;
}

.lms-action-card--song .lms-action-card__footer,
.lms-action-card--song .lms-action-card__icon {
    color: #ffd700;
}

.lms-access-pending {
    min-height: calc(100vh - 120px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 16px;
    background: #050505;
}

.lms-access-pending__card {
    max-width: 760px;
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(17, 17, 17, 0.98), rgba(10, 10, 10, 0.98));
    padding: 28px;
    color: #f5f5f5;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.45);
}

.lms-access-pending__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 14px;
}

.lms-access-pending__title {
    margin: 0 0 10px;
    font-size: 30px;
    line-height: 1.2;
    font-weight: 800;
    letter-spacing: -0.02em;
}

.lms-access-pending__body {
    margin: 0 0 20px;
    color: #b5b5b5;
    line-height: 1.65;
    font-size: 15px;
}

.lms-access-pending__steps {
    display: grid;
    gap: 10px;
    margin: 0 0 22px;
}

.lms-access-pending__step {
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.03);
    color: #d4d4d4;
    font-size: 14px;
}

.lms-access-pending__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.lms-access-pending__button,
.lms-access-pending__button:visited {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 16px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
}

.lms-access-pending__button--primary {
    background: #ffffff;
    color: #050505;
    border: 1px solid rgba(255, 255, 255, 0.25);
}

.lms-access-pending__button--ghost {
    background: transparent;
    color: #f5f5f5;
    border: 1px solid rgba(255, 255, 255, 0.22);
}

.payment-page {
    padding: 24px;
    color: #ffffff;
}

.payment-steps-wrap {
    display: flex;
    justify-content: center;
    padding: 18px 18px 0;
}

.payment-steps {
    display: flex;
    align-items: center;
    gap: 12px;
    max-width: 780px;
    width: 100%;
    justify-content: center;
    margin: 0 auto;
}

.payment-step {
    width: 56px;
    height: 56px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid rgba(255, 255, 255, 0.12);
    background: transparent;
    color: #ffffff;
    font-size: 20px;
    transition: transform 0.12s ease, box-shadow 0.12s ease, background 0.12s ease;
}

.payment-step.active {
    background: #ffffff;
    color: #000000;
    border-color: #ffffff;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.45);
    transform: translateY(-4px);
}

.payment-steps__line {
    flex: 1;
    height: 3px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 2px;
}

.payment-wrap {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 1100px;
    margin: 0 auto;
}

.payment-left,
.payment-right {
    flex: 1;
    width: 100%;
}

.payment-order-card {
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 20px;
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.2);
}

.payment-order-title,
.payment-method-title {
    margin-bottom: 12px;
}

.payment-order-header,
.payment-order-row,
.payment-order-meta,
.payment-order-total,
.payment-back-wrap {
    display: flex;
}

.payment-order-header,
.payment-order-row,
.payment-order-meta,
.payment-order-total {
    justify-content: space-between;
}

.payment-order-header {
    margin: 16px 0;
}

.payment-order-name {
    font-weight: 600;
}

.payment-order-note {
    opacity: 0.7;
    font-size: 13px;
}

.payment-order-amount {
    font-weight: 700;
}

.payment-order-divider {
    height: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    margin: 24px 0;
}

.payment-order-note-label {
    font-size: 13px;
    opacity: 0.85;
}

.payment-order-description {
    margin: 12px 0 32px;
}

.payment-order-referral {
    color: #b8f0c6;
    margin-top: 8px;
    font-weight: 600;
}

.payment-order-referral-code {
    margin-top: 6px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.75);
}

.payment-order-voucher-row {
    display: none;
    color: #b8f0c6;
    margin-top: 8px;
    font-weight: 600;
}

.payment-order-tax {
    color: rgba(255, 255, 255, 0.7);
    margin-top: 8px;
}

.payment-order-total-label {
    font-weight: 700;
}

.payment-order-total-amount {
    font-weight: 800;
    font-size: 1.1em;
}

.payment-method-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    gap: 12px;
}

.payment-option {
    display: block;
    cursor: pointer;
}

.payment-option-visual {
    min-height: 84px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    padding: 12px;
    transition: transform 0.14s ease, border-color 0.14s ease, background 0.14s ease;
}

.payment-option:hover .payment-option-visual {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
}

.payment-logo,
.payment-logo-fallback {
    width: 100%;
    max-width: 100px;
    height: 44px;
    object-fit: contain;
}

.payment-logo-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    font-size: 22px;
    font-weight: 800;
    text-transform: uppercase;
}

.payment-trust-signal {
    font-size: 14px;
    opacity: 0.8;
    margin-top: 24px;
}

.payment-voucher {
    margin-top: 18px;
}

.payment-voucher-label {
    font-size: 13px;
    opacity: 0.85;
    display: block;
}

.payment-voucher-row {
    display: flex;
    gap: 8px;
    align-items: center;
    max-width: 420px;
}

.payment-voucher-input {
    flex: 1;
    padding: 8px;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: transparent;
    color: #ffffff;
}

.payment-voucher-button {
    padding: 8px 12px;
    border-radius: 6px;
}

.payment-voucher-feedback {
    margin-top: 8px;
    font-size: 13px;
    color: #ffffdd;
}

.payment-primary-actions {
    margin-top: 24px;
    margin-bottom: 18px;
}

.payment-primary-button {
    background: #007bff;
    border-radius: 999px;
    padding: 14px 32px;
    color: #ffffff;
    border: none;
    font-weight: 700;
    font-size: 16px;
    cursor: pointer;
    width: 100%;
    max-width: 340px;
}

.payment-complete {
    margin-top: 36px;
}

.payment-back-wrap {
    max-width: 1100px;
    margin: 12px auto 40px;
    justify-content: flex-end;
    padding: 0 16px;
}

.payment-back-link {
    color: #ffffff;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 10px 14px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.02);
}

@media (min-width: 900px) {
    .payment-wrap {
        flex-direction: row;
        gap: 40px;
        align-items: flex-start;
    }

    .payment-order-card {
        max-width: 420px;
    }
}

@media (max-width: 480px) {
    .payment-page {
        padding: 16px;
    }

    .payment-steps-wrap {
        padding-left: 16px;
        padding-right: 16px;
    }
}

.upcoming {
    padding: 40px 20px;
    color: rgba(255, 255, 255, 0.95);
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 120px);
    box-sizing: border-box;
}

.slot {
    border-radius: 10px;
    margin-bottom: 18px;
    padding: 0;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.04);
}

.slot .card-body {
    padding: 18px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-start;
    flex-wrap: wrap;
}

.slot .meta {
    font-size: 14px;
    opacity: 0.9;
    margin-bottom: 6px;
}

.slot .info {
    flex: 1 1 60%;
    min-width: 0;
}

.slot .topic {
    font-weight: 800;
    font-size: 16px;
    margin-bottom: 6px;
}

.slot .label {
    color: rgba(255, 255, 255, 0.75);
    font-size: 13px;
    margin-right: 6px;
}

.slot .muted {
    color: rgba(255, 255, 255, 0.7);
    font-size: 14px;
}

.slot hr {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    margin: 10px 0;
}

.slot .btn {
    padding: 8px 18px;
    border-radius: 12px;
    background: #e5e7eb;
    color: #111827;
    font-weight: 700;
    text-decoration: none;
    border: none;
    transition: transform 0.12s ease, box-shadow 0.12s ease, background 0.12s ease, color 0.12s ease;
}

.slot .btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.35);
}

.countdown {
    display: inline-block;
    padding: 8px 12px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.6px;
    background: rgba(255, 255, 255, 0.06);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.07);
    min-width: 88px;
    text-align: center;
}

.countdown.soon {
    background: #ffffff;
    color: #111111;
    border-color: rgba(0, 0, 0, 0.06);
}

.countdown.live {
    background: #111111;
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.06);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.55);
}

.no-appointments {
    opacity: 0.85;
}

.make-another {
    position: fixed;
    right: 36px;
    bottom: 36px;
    z-index: 60;
}

.make-another .btn {
    padding: 12px 22px;
    border-radius: 12px;
    border: 2px solid rgba(255, 255, 255, 0.9);
    background: transparent;
    color: #ffffff;
    font-weight: 800;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.12s ease, box-shadow 0.12s ease, background 0.12s ease, color 0.12s ease;
}

.make-another .btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.6);
    background: #ffffff;
    color: #111827;
}

.rejected-note {
    margin-top: 6px;
}

.start-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    flex: 0 0 160px;
}

.start-wrap .countdown {
    margin-left: 0;
}

.status-badge {
    display: inline-block;
    padding: 6px 10px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 12px;
    margin-left: 8px;
    letter-spacing: 0.4px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.04);
    color: #ffffff;
}

.status-badge.rejected {
    background: transparent;
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.12);
}

.status-badge.pending {
    background: rgba(255, 255, 255, 0.06);
    color: #ffffff;
    border-style: dashed;
    border-color: rgba(255, 255, 255, 0.08);
}

.status-badge.scheduled {
    background: rgba(255, 255, 255, 0.08);
    color: #f3f4f6;
    border-color: rgba(255, 255, 255, 0.18);
}

.status-badge.on-going {
    background: #facc15;
    color: #111111;
    border-color: rgba(0, 0, 0, 0.12);
    font-weight: 800;
}

.status-badge.finished {
    background: rgba(185, 28, 28, 0.2);
    color: #fecaca;
    border-color: rgba(248, 113, 113, 0.45);
    font-weight: 700;
}

.slot.history {
    background: rgba(0, 0, 0, 0.45) !important;
    border-color: rgba(255, 255, 255, 0.03) !important;
}

.slot.history .topic {
    color: rgba(255, 255, 255, 0.95);
}

.slot.history .muted,
.slot.history .meta {
    color: rgba(255, 255, 255, 0.75);
}

.slot.history .status-badge {
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.06);
}

.btn-reschedule {
    background: transparent;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 8px 12px;
    border-radius: 8px;
}

.notes-wrap {
    margin-top: 6px;
}

.notes-label {
    color: rgba(255, 255, 255, 0.82);
    font-weight: 700;
    margin-right: 6px;
}

.meeting-finished-box {
    display: inline-block;
    margin-top: 8px;
    background: rgba(185, 28, 28, 0.2);
    color: #fecaca;
    border: 1px solid rgba(248, 113, 113, 0.45);
    border-radius: 8px;
    padding: 6px 10px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.2px;
}

@media (max-width: 992px) {
    .upcoming {
        padding: 28px 14px;
        min-height: calc(100vh - 140px);
    }

    .slot .info {
        flex: 1 1 100%;
    }

    .start-wrap {
        flex: 0 0 100%;
        align-items: flex-start;
    }

    .slot .card-body {
        gap: 10px;
    }

    .make-another {
        right: 18px;
        bottom: 18px;
    }
}

@media (max-width: 576px) {
    .slot .card-body {
        flex-direction: column;
        align-items: stretch;
    }

    .slot .info {
        width: 100%;
    }

    .start-wrap {
        width: 100%;
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
    }

    .start-wrap .countdown {
        margin-top: 0;
    }

    .slot .topic {
        font-size: 15px;
    }
}

.pay-wrapper {
    min-height: 74vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    background: #000000;
    color: #ffffff;
}

.pay-wrapper .pay-card {
    width: 100%;
    max-width: 940px;
    padding: 48px 52px;
    border: 1px solid #151515;
    border-radius: 22px;
    background: linear-gradient(180deg, #0c0c0c, #050505);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.55);
    position: relative;
    overflow: hidden;
}

.pay-wrapper .pay-card.success::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 25%, rgba(16, 185, 129, 0.12), transparent 60%);
    pointer-events: none;
}

.pay-wrapper .icon-wrap {
    width: 90px;
    height: 90px;
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 0 26px;
    background: rgba(255, 255, 255, 0.05);
}

.pay-wrapper .title {
    margin: 0 0 14px;
    font-size: 34px;
    font-weight: 800;
    letter-spacing: 0.5px;
}

.pay-wrapper .lead {
    margin: 0 0 26px;
    max-width: 720px;
    font-size: 16px;
    line-height: 1.55;
    opacity: 0.92;
}

.pay-wrapper .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
    margin: 4px 0 24px;
}

.pay-wrapper .info-item {
    padding: 16px 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    border-radius: 12px;
}

.pay-wrapper .info-item span {
    display: block;
    font-size: 11px;
    letter-spacing: 0.5px;
    opacity: 0.55;
    text-transform: uppercase;
    margin-bottom: 6px;
}

.pay-wrapper .status-pill {
    display: inline-block;
    padding: 4px 10px;
    font-size: 11px;
    border-radius: 40px;
    background: rgba(255, 255, 255, 0.12);
    letter-spacing: 0.5px;
}

.pay-wrapper .status-pill.ok {
    background: rgba(16, 185, 129, 0.18);
    color: #34d399;
}

.pay-wrapper .section-block {
    margin: 18px 0 8px;
}

.pay-wrapper .section-head {
    margin: 0 0 8px;
    font-size: 20px;
    font-weight: 700;
}

.pay-wrapper .section-text {
    margin: 0 0 14px;
    line-height: 1.55;
    font-size: 14px;
    opacity: 0.85;
}

.pay-wrapper .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
}

.pay-wrapper .actions.center {
    justify-content: center;
}

.pay-wrapper .btn-primary,
.pay-wrapper .btn-outline {
    padding: 14px 26px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: 0.18s ease;
    border: 1px solid transparent;
    cursor: pointer;
}

.pay-wrapper .btn-primary {
    background: #ffffff;
    color: #000000;
}

.pay-wrapper .btn-primary:hover {
    background: #e9e9e9;
}

.pay-wrapper .btn-outline {
    background: transparent;
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.22);
}

.pay-wrapper .btn-outline:hover {
    background: rgba(255, 255, 255, 0.12);
}

.pay-wrapper .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.25), transparent);
    margin: 34px 0 30px;
}

.pay-wrapper .extras {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 18px;
}

.pay-wrapper .extra-box {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    border-radius: 14px;
    padding: 18px 20px;
}

.pay-wrapper .extra-head {
    font-size: 13px;
    letter-spacing: 0.6px;
    font-weight: 600;
    opacity: 0.75;
    text-transform: uppercase;
    margin-bottom: 10px;
}

.pay-wrapper .copy-row {
    display: flex;
    align-items: center;
    gap: 10px;
}

.pay-wrapper .copy-row code {
    background: rgba(255, 255, 255, 0.08);
    padding: 6px 10px;
    border-radius: 8px;
    font-size: 13px;
}

.pay-wrapper .btn-copy {
    background: #1e1e1e;
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #ffffff;
    padding: 6px 14px;
    border-radius: 8px;
    font-size: 12px;
    cursor: pointer;
}

.pay-wrapper .btn-copy:hover {
    background: #2a2a2a;
}

.pay-wrapper .link-text {
    color: #ffffff;
    text-decoration: underline;
    font-weight: 600;
    font-size: 14px;
}

.pay-wrapper .tiny {
    font-size: 12px;
    line-height: 1.45;
    opacity: 0.75;
}

@media (max-width: 720px) {
    .pay-wrapper {
        padding: 24px;
    }

    .pay-wrapper .pay-card {
        padding: 38px 26px;
    }

    .pay-wrapper .title {
        font-size: 28px;
    }

    .pay-wrapper .lead {
        font-size: 15px;
    }

    .pay-wrapper .info-grid {
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    }
}

.kelas-thankyou-page {
    min-height: 72vh;
    background: #000000;
    color: #ffffff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 24px;
}

.kelas-thankyou-steps-wrap {
    display: flex;
    align-items: center;
    gap: 14px;
    max-width: 720px;
    width: 100%;
    justify-content: center;
    padding-top: 20px;
}

.kelas-thankyou-body {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
}

.kelas-thankyou-inner {
    text-align: center;
    max-width: 820px;
    padding: 60px 20px;
    color: #ffffff;
}

.thankyou-card {
    margin: 24px auto 26px auto;
    max-width: 780px;
    padding: 32px 36px;
    border-radius: 12px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.01));
    border: 1px solid rgba(255, 255, 255, 0.04);
    box-shadow: 0 6px 30px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.01);
    text-align: center;
}

.thankyou-head {
    margin: 0 0 10px;
    font-size: 28px;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.2px;
}

.thankyou-sub {
    margin: 0 auto 18px;
    color: rgba(255, 255, 255, 0.9);
    font-size: 15px;
    line-height: 1.6;
    max-width: 680px;
}

.purchase-summary {
    margin: 8px auto 18px;
    color: rgba(255, 255, 255, 0.95);
    font-size: 14px;
}

.purchase-line {
    margin: 6px 0;
}

.purchase-line--spaced {
    margin-top: 6px;
}

.thankyou-compact-box {
    margin-top: 18px;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
    text-align: left;
}

.thankyou-compact-card {
    border: 1px dashed rgba(255, 255, 255, 0.06);
    padding: 16px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.01);
}

.thankyou-compact-title {
    margin: 0 0 8px;
    color: #ffffff;
}

.thankyou-compact-copy {
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.5;
    font-size: 14px;
    margin-bottom: 10px;
}

.thankyou-benefits-wrap {
    margin-top: 12px;
    text-align: left;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
}

.thankyou-benefits-label {
    font-size: 14px;
    opacity: 0.85;
    margin-bottom: 8px;
}

.thankyou-benefits-copy {
    font-size: 13px;
    opacity: 0.95;
}

.thankyou-list {
    margin: 0 0 0 18px;
    padding: 0;
}

.thankyou-list-item {
    margin-bottom: 6px;
}

.thankyou-summary-card {
    margin: 24px auto 26px;
    max-width: 640px;
    text-align: left;
    padding: 18px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.03);
}

.thankyou-summary-title {
    margin-top: 0;
    margin-bottom: 8px;
}

.thankyou-summary-label {
    font-size: 14px;
    opacity: 0.85;
    margin-bottom: 10px;
}

.thankyou-summary-copy {
    font-size: 13px;
    opacity: 0.9;
}

.thankyou-summary-note {
    opacity: 0.8;
}

.thankyou-account-card {
    margin: 24px auto 26px;
    max-width: 640px;
    text-align: left;
    padding: 18px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.03);
}

.thankyou-account-title {
    margin-top: 0;
    margin-bottom: 8px;
}

.thankyou-account-line {
    font-size: 14px;
    opacity: 0.85;
}

.thankyou-footer-space {
    width: 100%;
    height: 1px;
}

.song-tutorial-page {
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 18px;
    color: #ffffff;
}

.song-tutorial-title {
    font-size: 22px;
    margin-bottom: 20px;
}

.topic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 18px;
}

.topic-card {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(0, 0, 0, 0.25));
    border-radius: 12px;
    overflow: hidden;
    padding: 12px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.03);
    transition: transform 0.28s cubic-bezier(.2, .9, .2, 1), box-shadow 0.28s, border-color 0.2s;
    display: block;
    color: inherit;
}

.topic-card:focus,
.topic-card:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.7);
    border-color: rgba(100, 220, 255, 0.12);
}

.topic-thumb {
    background: #111111;
    height: 140px;
    border-radius: 10px;
    overflow: hidden;
    display: block;
    position: relative;
}

.topic-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s, filter 0.3s;
}

.topic-card:hover .topic-thumb img {
    transform: scale(1.03);
    filter: brightness(0.95) contrast(1.02);
}

.topic-title {
    padding-top: 12px;
    color: rgba(255, 255, 255, 0.94);
    font-weight: 700;
    font-size: 15px;
}

.song-tutorial-note {
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 18px;
}

.song-tutorial-gate {
    background: linear-gradient(180deg, #0f1724, #050607);
    padding: 28px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 18px;
}

.song-tutorial-gate__body {
    flex: 1;
}

.song-tutorial-gate__title {
    margin: 0 0 8px;
    color: #ffffff;
}

.song-tutorial-gate__copy {
    margin: 0;
    color: rgba(255, 255, 255, 0.78);
}

.song-tutorial-gate__actions {
    flex: 0;
}

.coaching-checkout {
    max-width: 980px;
    margin: 28px auto;
    padding: 0 16px;
}

.coaching-checkout__steps {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin: 0 0 18px;
}

.coaching-checkout__step {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111111;
    background: #ffffff;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.35);
    position: relative;
}

.coaching-checkout__step i {
    font-size: 18px;
}

.coaching-checkout__step:not(.active) {
    opacity: 0.55;
    background: rgba(255, 255, 255, 0.9);
}

.coaching-checkout__line {
    flex: 0 0 54px;
    height: 2px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.25), rgba(255, 255, 255, 0.05));
    border-radius: 2px;
}

.coaching-checkout__step.active {
    outline: 2px solid rgba(255, 255, 255, 0.85);
    box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.08), 0 12px 28px rgba(0, 0, 0, 0.55);
}

.coaching-checkout__card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
}

.coaching-checkout__body {
    padding: 20px;
    color: #ffffff;
}

.coaching-checkout__title {
    margin: 0 0 10px;
    font-weight: 800;
    font-size: 18px;
    color: #ffffff;
}

.coaching-checkout__muted {
    color: rgba(255, 255, 255, 0.75);
}

.coaching-checkout__summary-grid {
    display: flex;
    gap: 20px;
    align-items: flex-start;
}

.coaching-checkout__col {
    flex: 1 1 0;
}

.coaching-checkout__side {
    width: 340px;
    flex: 0 0 340px;
}

.coaching-checkout__info-block {
    border-radius: 10px;
    padding: 14px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
}

.coaching-checkout__info-block + .coaching-checkout__info-block {
    margin-top: 12px;
}

.coaching-checkout__info-label {
    font-weight: 800;
    font-size: 14px;
    color: #ffffff;
}

.coaching-checkout__info-value {
    margin-top: 6px;
}

.coaching-checkout__price {
    margin-top: 8px;
    font-size: 20px;
    font-weight: 900;
}

.coaching-checkout__payment-title {
    display: flex;
    align-items: center;
    gap: 10px;
}

.coaching-checkout__pay-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #111111;
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.2), 0 12px 24px rgba(0, 0, 0, 0.45);
    position: relative;
}

.coaching-checkout__pay-icon::after {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 14px;
    background: radial-gradient(60% 60% at 50% 50%, rgba(255, 255, 255, 0.25), rgba(255, 255, 255, 0));
    pointer-events: none;
}

.coaching-checkout__total-line {
    margin-top: 8px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.8);
}

.coaching-checkout__total-amount {
    font-weight: 900;
    font-size: 22px;
    margin-top: 6px;
}

.coaching-checkout__pay-spacer {
    margin-top: 12px;
}

.coaching-checkout__pay-note {
    margin-top: 8px;
    font-size: 12px;
}

@media (max-width: 860px) {
    .coaching-checkout__summary-grid {
        flex-direction: column;
    }

    .coaching-checkout__side {
        width: 100%;
        flex: 1 1 auto;
    }
}

.song-show-container {
    display: flex;
}

.song-show-sidebar {
    width: 250px;
    border-right: 1px solid #222222;
    padding: 1rem;
    background: #0f0f0f;
}

.song-show-logo {
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
}

.song-show-menu {
    list-style: none;
    padding: 0;
}

.song-show-lesson {
    margin-bottom: 0.5rem;
}

.song-show-lesson-header {
    display: flex;
    align-items: center;
    cursor: pointer;
    padding: 0.25rem 0;
    justify-content: space-between;
    text-decoration: none;
}

.song-show-lesson-left {
    display: flex;
    align-items: center;
}

.song-show-lesson-logo {
    width: 28px;
    height: 28px;
    margin-right: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #222222;
    border-radius: 6px;
    font-size: 14px;
    line-height: 24px;
    text-align: center;
    color: #ffffff;
}

.song-show-lesson-arrow {
    display: inline-block;
    width: 18px;
    text-align: center;
}

.song-show-topic-list {
    list-style: none;
    padding-left: 28px;
    display: none;
    margin-top: 8px;
    position: relative;
}

.song-show-main {
    flex: 1;
    padding: 1rem;
}

.song-show-actions {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-bottom: 12px;
}

.song-show-backlink {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
}

.song-show-backlink svg {
    width: 18px;
    height: 18px;
}

.coaching-thank-page {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 16px;
}

.coaching-thank-wrap {
    width: 100%;
    max-width: 980px;
}

.coaching-thank-steps {
    width: 100%;
    max-width: 820px;
    margin: 0 auto 26px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}

.coaching-thank-step {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.12);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.9);
}

.coaching-thank-step.complete {
    background: rgba(255, 255, 255, 0.95);
    color: #000000;
}

.coaching-thank-line {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.95);
    margin: 0 12px;
}

.coaching-thank-inner {
    text-align: center;
    color: rgba(255, 255, 255, 0.95);
}

.coaching-thank-inner h1 {
    font-weight: 600;
    font-size: 28px;
    margin-bottom: 12px;
}

.coaching-thank-inner p {
    opacity: 0.85;
    margin-bottom: 22px;
}

.coaching-thank-button {
    display: inline-block;
    padding: 12px 26px;
    border-radius: 24px;
    background: #ffffff;
    color: #000000;
    font-weight: 700;
    text-decoration: none;
}

.admin-coaching-nav {
    margin-bottom: 18px;
    display: flex;
    gap: 12px;
    align-items: center;
}

.admin-audit {
    max-width: 1100px;
    margin: 0 auto;
    padding: 16px;
    color: #ffffff;
}

.admin-audit__title {
    margin: 0 0 12px;
}

.admin-audit__intro {
    opacity: 0.75;
    margin-bottom: 16px;
}

.admin-audit__form {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 10px;
    margin-bottom: 16px;
    background: #0b0b0b;
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 12px;
    border-radius: 8px;
}

.admin-audit__label {
    display: block;
    margin-bottom: 6px;
}

.admin-audit__control {
    width: 100%;
    padding: 10px;
    border-radius: 6px;
    background: #111111;
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: #ffffff;
}

.admin-audit__actions {
    grid-column: 1 / -1;
    text-align: right;
}

.admin-audit__reset {
    margin-left: 8px;
}

.admin-audit__table-wrap {
    overflow-x: auto;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
}

.admin-audit__table {
    width: 100%;
    border-collapse: collapse;
}

.admin-audit__head-row {
    background: #0f0f0f;
}

.admin-audit__head-cell,
.admin-audit__cell {
    text-align: left;
    padding: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.admin-audit__cell--nowrap {
    white-space: nowrap;
}

.admin-audit__meta {
    font-size: 12px;
    opacity: 0.9;
}

.admin-audit__empty {
    padding: 14px;
    text-align: center;
    opacity: 0.7;
}

.admin-audit__footer {
    margin-top: 12px;
}

.kelas-container {
    display: flex;
}

.sidebar {
    width: 250px;
    border-right: 1px solid #222222;
    padding: 1rem;
    background: #0f0f0f;
}

.lesson-title {
    font-weight: 400;
    margin-top: 0;
    font-size: 15px;
    color: #cfcfcf;
}

.lesson-block .lesson-title {
    transition: color 0.12s ease, font-weight 0.12s ease;
}

.lesson-block.active .lesson-title {
    color: #ffffff;
    font-weight: 700;
}

.topic-item {
    cursor: pointer;
    padding-left: 1rem;
    font-size: 13px;
    color: #bfbfbf;
}

.topic-item.disabled {
    color: #999999;
    cursor: default;
    padding-left: 1rem;
}

.main-wrapper {
    flex: 1;
    padding: 1rem;
}

.topic-item.completed {
    color: #9fd19f;
}

body,
.main-wrapper,
.sidebar,
.kelas-container {
    font-family: 'Inter', 'Poppins', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.video-placeholder {
    background-size: cover;
    background-position: center;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
}

.custom-play-btn {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    cursor: pointer;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.6);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
}

.custom-play-btn::before {
    content: '';
    display: block;
    width: 0;
    height: 0;
    border-left: 28px solid #ffffff;
    border-top: 18px solid transparent;
    border-bottom: 18px solid transparent;
    position: relative;
    margin-left: 6px;
}

.player-wrapper {
    max-width: 1100px;
    margin: 1rem auto;
}

.player-wrapper #player {
    width: 100%;
    aspect-ratio: 16 / 9;
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.04);
}

.player-wrapper iframe,
.player-wrapper .video-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
}

.player-wrapper .video-placeholder {
    z-index: 1;
}

.player-wrapper iframe {
    z-index: 3;
}

.main-wrapper .navbar {
    margin-bottom: 1rem;
}

.main-wrapper .content {
    padding-top: 1rem;
}

.video-meta {
    margin-bottom: 1.5rem;
}

#video-description,
.video-meta,
.video-meta * {
    overflow-wrap: break-word;
    word-wrap: break-word;
    overflow: visible;
    word-break: break-word;
    white-space: normal;
    max-width: 100%;
}

.lesson-header {
    padding: 8px 6px;
    margin-bottom: 2px;
    border-radius: 6px;
}

.lesson-arrow {
    width: 18px;
    display: inline-block;
    color: #bbbbbb;
    margin-left: 6px;
}

.lesson-logo {
    background: #222222;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.topic-list {
    position: relative;
    padding-left: 28px;
    margin-top: 8px;
}

.lesson-block.active > .lesson-header {
    position: relative;
}

.lesson-block.active > .lesson-header::before {
    content: '';
    position: absolute;
    left: -12px;
    top: 2px;
    bottom: 2px;
    width: 3px;
    background: #ffffff;
    border-radius: 2px;
}

.lesson-header:hover {
    background: rgba(255, 255, 255, 0.02);
}

.lesson-block.active .lesson-title {
    color: #ffffff;
}

.video-controls {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 12px;
}

.video-nav-btn {
    font-family: 'Poppins', 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 16px;
    padding: 12px 20px;
    border-radius: 12px;
    border: 0;
    cursor: pointer;
    transition: transform 0.12s ease, box-shadow 0.12s ease, background-color 0.12s ease, color 0.12s ease;
    position: relative;
    overflow: hidden;
}

.video-nav-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
}

.video-nav-btn#btn-prev {
    background: linear-gradient(180deg, #ffffff, #f2f2f2);
    color: #111111;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.25);
}

.video-nav-btn#btn-next {
    background: linear-gradient(180deg, #111111, #0a0a0a);
    color: #ffffff;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.04);
}

.video-nav-btn#btn-prev:hover:not(:disabled) {
    transform: translateY(-4px);
    box-shadow: 0 26px 60px rgba(0, 0, 0, 0.35);
}

.video-nav-btn#btn-next:hover:not(:disabled) {
    transform: translateY(-4px);
    box-shadow: 0 26px 80px rgba(0, 0, 0, 0.5);
}

.video-nav-btn#btn-prev:active,
.video-nav-btn#btn-next:active {
    transform: translateY(-2px);
}

.video-nav-btn svg {
    width: 18px;
    height: 18px;
    display: inline-block;
}

.video-nav-btn .label {
    display: inline-block;
}

.video-nav-btn::after {
    content: '';
    position: absolute;
    left: -60%;
    top: 0;
    width: 40%;
    height: 100%;
    background: linear-gradient(120deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.06));
    transform: skewX(-18deg) translateX(0);
    transition: transform 0.9s ease;
    pointer-events: none;
}

.video-nav-btn:hover::after {
    transform: translateX(200%);
}

.ripple {
    position: absolute;
    border-radius: 999px;
    transform: scale(0);
    background: rgba(255, 255, 255, 0.14);
    animation: ripple 0.6s linear;
    pointer-events: none;
}

@keyframes ripple {
    to {
        transform: scale(6);
        opacity: 0;
    }
}

.topic-list {
    position: relative;
    padding-left: 28px;
    margin-top: 8px;
}

.topic-item {
    position: relative;
    padding: 8px 12px 8px 28px;
    border-radius: 4px;
    transition: background-color 0.15s ease;
    display: flex;
    align-items: center;
    line-height: 1.35;
    text-indent: 0;
    word-break: break-word;
    white-space: normal;
}

.topic-item:hover {
    background: rgba(255, 255, 255, 0.04);
}

.topic-item.selected {
    color: #ffffff;
    font-weight: 600;
    background: rgba(255, 255, 255, 0.08);
    border-left: 3px solid #ffffff;
    padding-left: 19px;
}

.topic-box {
    padding: 8px 12px;
}

@media (max-width: 900px) {
    .kelas-container {
        flex-direction: row;
    }

    .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        width: 300px;
        max-width: 80%;
        transform: translateX(-110%);
        transition: transform 0.28s ease;
        z-index: 1200;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
    }

    .sidebar.active {
        transform: translateX(0);
    }

    #sidebar-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        opacity: 0;
        transition: opacity 0.22s ease;
        z-index: 1100;
        display: none;
    }

    #sidebar-backdrop.visible {
        display: block;
        opacity: 1;
    }

    .lesson-header {
        padding: 12px 10px;
    }

    .topic-item {
        padding: 10px 14px 10px 34px;
    }

    .main-wrapper {
        padding: 0.75rem;
    }

    .player-wrapper {
        max-width: 100%;
        margin: 0.5rem 0;
    }

    .player-wrapper #player {
        border-radius: 10px;
    }

    .navbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 8px 0;
    }

    .nav-left .burger {
        font-size: 20px;
        padding: 8px 10px;
        border-radius: 8px;
    }

    body:not(.sidebar-open) .main-wrapper {
        margin-left: 0;
    }
}

@media (max-width: 480px) {
    .lesson-title {
        font-size: 14px;
    }

    .topic-item {
        font-size: 14px;
    }

    .video-nav-btn {
        padding: 10px 14px;
        font-size: 15px;
    }

    .custom-play-btn {
        width: 72px;
        height: 72px;
    }
}

.kelas-navbar {
    background: #000000;
    color: #ffffff;
    padding: 14px 20px;
    border-bottom: 1px solid #111111;
    position: sticky;
    top: 0;
    z-index: 60;
}

.kelas-navbar__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.kelas-navbar__links {
    display: flex;
    align-items: center;
    gap: 18px;
}

.kelas-navbar__brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
}

.kelas-navbar__logo {
    height: 30px;
    display: block;
}

.kelas-navbar__link {
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
}

.kelas-navbar__link--strong {
    font-weight: 600;
}

.kelas-navbar__actions {
    display: flex;
    align-items: center;
    gap: 10px;
}

.kelas-navbar__user {
    opacity: 0.9;
    margin-right: 8px;
}

.kelas-navbar__logout {
    background: transparent;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 6px 10px;
    border-radius: 6px;
}